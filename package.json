{
  "name": "verifactu",
  "version": "0.1.0",
  "description": "Librería TypeScript totalmente libre para VeriFactu (AEAT): registros, huella encadenada, QR y verificador de cumplimiento. Sin APIs de pago.",
  "type": "module",
  "license": "MIT",
  "author": "Ignacio Noguerol (inoguerols)",
  "homepage": "https://github.com/inoguerols/verifactu",
  "repository": { "type": "git", "url": "git+https://github.com/inoguerols/verifactu.git" },
  "keywords": ["verifactu", "aeat", "facturacion", "factura", "hacienda", "antifraude", "spain", "tax", "invoice"],
  "exports": { ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" } },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": { "verifactu": "./dist/cli.js" },
  "files": ["dist", "spec"],
  "scripts": {
    "build": "tsup",
    "prepare": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "validate:xsd": "xmllint --noout --schema spec/xsd/SuministroLR.xsd"
  },
  "dependencies": {
    "fast-xml-parser": "^4.5.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/qrcode": "^1.5.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": { "node": ">=18" }
}
