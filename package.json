{
  "name": "@inoguerols/verifactu",
  "version": "1.2.1",
  "description": "Librería y CLI TypeScript libres (MIT) para VeriFactu (AEAT): huella encadenada SHA-256, QR de cotejo, verificador de cumplimiento, generación de XML (XSD oficial), envío al web service (TLS mutuo), firma XAdES y servidor MCP. Sin APIs de pago ni terceros.",
  "type": "module",
  "license": "MIT",
  "author": "Ignacio Noguerol (inoguerols)",
  "homepage": "https://github.com/inoguerols/verifactu",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inoguerols/verifactu.git"
  },
  "keywords": [
    "verifactu",
    "aeat",
    "facturacion",
    "factura",
    "hacienda",
    "antifraude",
    "spain",
    "tax",
    "invoice"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "verifactu": "dist/cli.js",
    "verifactu-mcp": "dist/mcp.js"
  },
  "files": [
    "dist",
    "spec"
  ],
  "scripts": {
    "build": "tsup",
    "prepare": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "validate:xsd": "xmllint --noout --schema spec/xsd/SuministroLR.xsd"
  },
  "dependencies": {
    "@peculiar/webcrypto": "^1.7.1",
    "@xmldom/xmldom": "^0.8.13",
    "fast-xml-parser": "^4.5.0",
    "qrcode": "^1.5.4",
    "xadesjs": "^2.6.7",
    "xml-core": "^1.2.5",
    "xmldsigjs": "^2.8.7",
    "xpath": "^0.0.34"
  },
  "optionalDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@peculiar/x509": "^2.0.0",
    "@types/node": "^22.10.0",
    "@types/qrcode": "^1.5.5",
    "reflect-metadata": "^0.2.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18"
  }
}
